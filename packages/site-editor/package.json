{
  "name": "site-editor",
  "version": "1.1.0",
  "description": "SciEngTech site editor – Electron + React",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "package:win": "node scripts/prepare-oauth-config.mjs --strict && npm run build && electron-builder --win",
    "copy:tinymce": "node scripts/copy-tinymce.mjs",
    "postinstall": "electron-builder install-app-deps && node scripts/copy-tinymce.mjs"
  },
  "keywords": [],
  "author": "SciEngTech",
  "license": "ISC",
  "build": {
    "appId": "in.sciengtech.site-editor",
    "productName": "SciEngTech Site Editor",
    "directories": {
      "output": "release"
    },
    "files": [
      "out/**/*",
      "package.json"
    ],
    "win": {
      "target": "nsis"
    }
  },
  "dependencies": {
    "@hookform/resolvers": "^4.1.3",
    "@tinymce/tinymce-react": "^6.3.0",
    "clsx": "^2.1.1",
    "dotenv": "^16.5.0",
    "lucide-react": "^0.511.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-hook-form": "^7.56.4",
    "simple-git": "^3.27.0",
    "tailwind-merge": "^3.3.0",
    "tinymce": "^8.0.2",
    "zod": "^3.25.42"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.8",
    "@types/react": "^19.1.6",
    "@types/react-dom": "^19.1.5",
    "@vitejs/plugin-react-swc": "^4.3.1",
    "electron": "^33.4.11",
    "electron-builder": "^26.15.3",
    "electron-vite": "^5.0.0",
    "tailwindcss": "^4.1.8",
    "typescript": "^5.8.3",
    "vite": "^7.3.6"
  }
}
