{
  "name": "sciengtech-revamp",
  "version": "1.0.0",
  "description": "Interactive homepage prototype for [sciengtech.in](https://sciengtech.in/) repositioning.",
  "main": "index.js",
  "directories": {
    "doc": "docs"
  },
  "scripts": {
    "ingest": "node scripts/ingest-writeup.mjs",
    "review:writeup": "node scripts/generate-writeup-image-review.mjs",
    "review:writeup:open": "node scripts/generate-writeup-image-review.mjs && npx serve -l 3456 .",
    "slides": "node scripts/generate-slide-placeholders.mjs",
    "migrate-knowledge": "node scripts/migrate-knowledge.mjs",
    "build": "node scripts/generate-slide-placeholders.mjs && node scripts/ingest-writeup.mjs && node scripts/build-site.mjs",
    "build:site": "node scripts/build-site.mjs",
    "apply-images": "node scripts/apply-image-selections.mjs && node scripts/build-site.mjs",
    "export-inventory": "node scripts/export-product-inventory.mjs",
    "serve": "npx serve -l 3456 ."
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/karpe29/sciengtech-revamp.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/karpe29/sciengtech-revamp/issues"
  },
  "homepage": "https://karpe29.github.io/sciengtech-revamp/",
  "devDependencies": {
    "mammoth": "^1.12.0",
    "xlsx": "^0.18.5"
  }
}
